rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin-only collections — no public access
    match /clients/{doc} {
      allow read, write: if request.auth != null;
    }
    match /orders/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    // Leads — public create (from /start funnel, no auth), admin read/update/delete
    match /leads/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /broadcastLogs/{doc}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    // Public write allowed — for cart and subscriber capture from site
    match /subscribers/{doc} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }
    match /abandonedCarts/{doc} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }

    // Scheduled emails — functions only
    match /scheduledEmails/{doc} {
      allow read, write: if request.auth != null;
    }

    // Products — public read, admin write
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reviews — public read and create, admin write
    match /reviews/{doc} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }
  }
}
