rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin-only collections — no public access
    match /clients/{doc} {
      allow read, write: if request.auth != null;
    }
    match /orders/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    // Leads — public create (from /start funnel, no auth), admin read/update/delete
    match /leads/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    // Waitlist — public create (from product pages, no auth), admin read/update/delete
    match /waitlist/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /broadcastLogs/{doc}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    // Public write allowed — for cart and subscriber capture from site
    match /subscribers/{doc} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }
    match /abandonedCarts/{doc} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }

    // Scheduled emails — functions only
    match /scheduledEmails/{doc} {
      allow read, write: if request.auth != null;
    }

    // Settings (bestSellers, site_settings, chatbot_knowledge) — public read, admin write
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Products — public read, admin write
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reviews — public read and create, admin write
    match /reviews/{doc} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Invoices — admin only
    match /invoices/{doc} {
      allow read, write: if request.auth != null;
    }

    // Jarvis outcome tracking — admin only (matches the auth account in jarvis.html)
    match /jarvis_outcomes/{doc} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "start@najahchemist.com";
    }

    // Marketing Commander campaigns — admin only (matches the auth account in jarvis.html)
    match /campaigns/{doc} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "start@najahchemist.com";
    }

    // ── Jarvis Operating System ───────────────────────────────────────────────
    // isAdmin(): keeps the existing single-email gate working today, and also
    // accepts a role custom-claim once role migration lands (Phase 6) — no flag-day.
    function isAdmin() {
      return request.auth != null
        && (request.auth.token.email == "start@najahchemist.com"
            || request.auth.token.role in ["Owner", "Admin"]);
    }

    // Lead intelligence — written ONLY by Cloud Functions (admin SDK bypasses rules).
    // Clients read-only; no client can ever write/tamper. This isolation is what
    // prevents contention with the auto-responder's writes to the `leads` doc.
    match /lead_intelligence/{leadId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Learning layer — admin read/create/update; never deleted (audit integrity).
    match /lead_recommendation_outcomes/{doc} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    // ── Recommendation Platform (Phases A–E) ──────────────────────────────────
    // Canonical recommendation records. Cloud Functions write the bulk (admin SDK
    // bypasses rules); the founder's manual Won/Lost/Snooze/Actioned transitions write
    // from the dashboard, so admin client writes are allowed. Never deleted — the
    // history[] array + terminal states ARE the recommendation archive (audit integrity).
    match /recommendations/{doc} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    // Reconciler proposals + integrity reports — written ONLY by Cloud Functions;
    // clients (admin dashboards) read-only.
    match /recommendation_resolution_proposals/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /recommendation_integrity_reports/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Function-written intelligence — clients read-only.
    match /revenue_opportunities/{doc} { allow read: if request.auth != null; allow write: if false; }
    match /product_intelligence/{doc}  { allow read: if request.auth != null; allow write: if false; }
    match /market_signals/{doc}        { allow read: if request.auth != null; allow write: if false; }
    match /daily_briefings/{doc}       { allow read: if request.auth != null; allow write: if false; }
    match /content_intelligence/{doc}  { allow read: if request.auth != null; allow write: if false; }
    match /agentPerformance/{doc}      { allow read: if request.auth != null; allow write: if false; }
    match /customerMemory/{doc}        { allow read: if request.auth != null; allow write: if false; }

    // Agent controls / kill switch — human (admin) only.
    match /agent_controls/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Approval queue — agents request (any auth), only admin decides; never deleted.
    match /pending_approvals/{doc} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Audit log — append-only / immutable.
    match /jarvis_audit_logs/{doc} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Revenue ledger — append-only / immutable money record.
    match /revenue_events/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Role bootstrap (custom-claims migration) — admin only.
    match /user_roles/{uid} {
      allow read, write: if isAdmin();
    }
  }
}
